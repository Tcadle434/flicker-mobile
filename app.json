{
  "expo": {
    "name": "Flicker",
    "slug": "flicker-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "flicker",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": false,
      "deploymentTarget": "16.0",
      "appleTeamId": "4DDM7M9LF2",
      "bundleIdentifier": "com.thomascadle.flicker",
      "appStoreUrl": "https://apps.apple.com/app/id6761934566",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSUserNotificationsUsageDescription": "Get notified about your daily ambient music sessions.",
        "NSFamilyControlsUsageDescription": "Flicker blocks distracting apps during sessions to help you stay focused.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "flicker",
              "com.googleusercontent.apps.150545303621-5pohfh6miii5ql7istcvr6devga1f9an"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.thomascadle.flicker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./modules/flicker-app-blocking/build/index",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      "expo-video"
    ]
  }
}
